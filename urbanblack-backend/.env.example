# ============================================================
# Urban Black Backend — Secrets Template
# Copy this file to .env and fill in real values.
# ============================================================

# PostgreSQL
DB_USERNAME=postgres
DB_PASSWORD=CHANGE_ME

# JWT — use a long random string in production (min 32 chars)
JWT_SECRET=CHANGE_ME_TO_RANDOM_64_CHAR_STRING

# Google Maps (server-side — used by ride-service GeoService)
GOOGLE_MAPS_API_KEY=YOUR_SERVER_MAPS_API_KEY

# BestSMS (used by auth-service)
SMS_AUTHKEY=YOUR_BESTSMS_AUTHKEY
SMS_DLT_ENTITY_ID=YOUR_19_DIGIT_ENTITY_ID
