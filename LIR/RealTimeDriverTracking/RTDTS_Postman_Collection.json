{
  "info": {
    "name": "UrbanBlack - Real-Time Driver Tracking System",
    "description": "API Tests for the Real-Time Driver Tracking service. Includes core flows for session management, GPS ingestion, and latest location retrieval.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Service Health",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "pm.test(\"Service is rtdts\", function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData.service).to.eql(\"rtdts\");",
              "    pm.expect(jsonData.status).to.eql(\"ok\");",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/health",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "health"
          ]
        }
      },
      "response": []
    },
    {
      "name": "1. Start Tracking Session",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "pm.test(\"Validation string 'started'\", function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData.status).to.eql(\"started\");",
              "    pm.expect(jsonData.driver_id).to.eql(pm.environment.get(\"driver_id\"));",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"driver_id\": \"{{driver_id}}\",\n  \"ride_id\": \"{{ride_id}}\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/tracking/session/start",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "tracking",
            "session",
            "start"
          ]
        }
      },
      "response": []
    },
    {
      "name": "2. Ingest GPS Fix",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "pm.test(\"Has smoothed coordinates\", function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData).to.have.property(\"smoothed_lat\");",
              "    pm.expect(jsonData).to.have.property(\"smoothed_lng\");",
              "    pm.expect(jsonData.driver_id).to.eql(pm.environment.get(\"driver_id\"));",
              "});",
              "pm.test(\"Response time is fast\", function () {",
              "    pm.expect(pm.response.responseTime).to.be.below(500);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"driver_id\": \"{{driver_id}}\",\n  \"lat\": 12.9715987,\n  \"lng\": 77.5945627,\n  \"accuracy_meters\": 5.2,\n  \"speed_kmh\": 45.5,\n  \"gps_source\": \"FUSED\",\n  \"is_on_trip\": true,\n  \"ride_id\": \"{{ride_id}}\",\n  \"timestamp\": \"2026-03-25T10:30:00Z\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/tracking/gps",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "tracking",
            "gps"
          ]
        }
      },
      "response": []
    },
    {
      "name": "3. Get Driver's Latest Location",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "pm.test(\"Verify returned data\", function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData.driver_id).to.eql(pm.environment.get(\"driver_id\"));",
              "    pm.expect(jsonData.smoothed_lat).to.be.a(\"number\");",
              "    pm.expect(jsonData.smoothed_lng).to.be.a(\"number\");",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/tracking/driver/{{driver_id}}/latest",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "tracking",
            "driver",
            "{{driver_id}}",
            "latest"
          ]
        }
      },
      "response": []
    },
    {
      "name": "4. Stop Tracking Session",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "pm.test(\"Validation string 'stopped'\", function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData.status).to.eql(\"stopped\");",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"driver_id\": \"{{driver_id}}\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/tracking/session/stop",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "tracking",
            "session",
            "stop"
          ]
        }
      },
      "response": []
    }
  ],
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          ""
        ]
      }
    },
    {
      "listen": "test",
      "script": {
        "type": "text/javascript",
        "exec": [
          ""
        ]
      }
    }
  ],
  "variable": [
    {
      "key": "base_url",
      "value": "http://127.0.0.1:8001",
      "type": "string"
    },
    {
      "key": "driver_id",
      "value": "DRIVER-98765",
      "type": "string"
    },
    {
      "key": "ride_id",
      "value": "RIDE-54321",
      "type": "string"
    }
  ]
}