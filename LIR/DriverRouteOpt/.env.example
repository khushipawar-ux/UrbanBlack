# ─────────────────────────────────────────────────────────────
# Urban Black — Route Optimization Engine
# Environment Variables — copy this to .env and fill in values
# ─────────────────────────────────────────────────────────────

ENV=development
DEBUG=true
PORT=8000
HOST=0.0.0.0

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=urban_black_db
DB_USER=postgres
DB_PASSWORD=admin123

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
CACHE_TTL_SECONDS=300

# Google Maps (get keys from console.cloud.google.com)
GOOGLE_MAPS_API_KEY=YOUR_API_KEY_HERE
GOOGLE_DIRECTIONS_KEY=
GOOGLE_DISTANCE_MATRIX_KEY=
GOOGLE_MAPS_TIMEOUT=5

# ML Model
MODEL_PATH=ml/saved_models/eta_lgbm_v1.pkl
MODEL_VERSION=lgbm_v1.0
TRAINING_DATA_PATH=data/rides_training.csv
MIN_TRAINING_ROWS=100

# Route Optimization
REROUTE_DEVIATION_METERS=200
REROUTE_POLL_SECONDS=30
ML_IMPROVEMENT_THRESHOLD=0.05
MAX_ROUTE_RESPONSE_MS=200
